# Managed database (e.g. Aiven): Service → Connection information → copy Service URI (includes user, password, sslmode)
# Example format:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/defaultdb?sslmode=require
DATABASE_URL=

# Optional
# PORT=3000
# UPLOAD_MAX_BYTES=52428800
# Optional: when hosting, set your public site URL so new invite links use it:
# PUBLIC_APP_URL=https://your-app.example.com

# Optional: subject line / template {{APP_NAME}} in contributor-invite-email.html (default: Jira Spillover Analyzer)
# INVITE_APP_NAME=Jira Spillover Analyzer

# Optional: server-sent invite email (required for Per-person links → Send — delivers HTML template to inbox).
# MAILERSEND_API_TOKEN=
# MAILERSEND_FROM_EMAIL=noreply@your-verified-domain.com
# MAILERSEND_FROM_NAME=Jira Spillover Analyzer
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Jira Spillover <noreply@yourdomain.com>"
