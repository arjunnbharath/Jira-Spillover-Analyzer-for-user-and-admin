# Managed database (e.g. Aiven): Service → Connection information → copy Service URI (includes user, password, sslmode)
# Example format:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/defaultdb?sslmode=require
DATABASE_URL=

# Optional
# PORT=3000
# UPLOAD_MAX_BYTES=52428800
# Full public URL of this app (used in invite links). If unset, the Host header is used.
# PUBLIC_APP_URL=https://your-app.example.com

