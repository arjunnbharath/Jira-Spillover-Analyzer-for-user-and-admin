{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "functions": {
    "api/index.js": {
      "includeFiles": "{express-app.js,analyzer.html,auth.html,user-dashboard.html,firebase-config.js,images/**,js/**,templates/**,db/**}",
      "maxDuration": 60
    }
  }
}
